# Copy to training/.env and edit. Loaded by train.py via python-dotenv.
# All values can also be exported inline (env wins over .env).

# --- Kaggle ---
# Path to a file containing the raw KGAT_... token (modern API token,
# downloaded from kaggle.com/settings → API Tokens). train.py reads this
# file and exports its contents as KAGGLE_TOKEN for kagglehub.
KAGGLE_TOKEN_FILE=~/.kaggle/access_token

# Kaggle dataset handle for Jigsaw. The default below mirrors the original
# 2018 competition data (160k train rows, 6 binary labels).
KAGGLE_DATASET=julian3833/jigsaw-toxic-comment-classification-challenge

# --- MLflow ---
# Point at the port-forwarded in-cluster MLflow server:
#   kubectl -n mlflow port-forward svc/mlflow 5000:5000
# artifacts are proxied by `mlflow server --serve-artifacts`, so no
# S3/MinIO creds are needed on the client side.
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT=toxicity-distilbert

# Set to "true" (any case) to also register the model in the MLflow Model
# Registry under MLFLOW_REGISTERED_MODEL_NAME. Off by default — flip on
# once a run is worth promoting toward M2.
MLFLOW_REGISTER_MODEL=false
MLFLOW_REGISTERED_MODEL_NAME=distilbert-toxicity

# --- Training (CPU short runs) ---
# Subsample of the 160k train rows actually used. 2000 ≈ 1 epoch in
# ~3 min on a laptop CPU. Set TRAIN_SAMPLE_LIMIT=-1 for full data.
TRAIN_SAMPLE_LIMIT=2000
EVAL_SAMPLE_LIMIT=200
MAX_LENGTH=128
TRAIN_BATCH_SIZE=16
EVAL_BATCH_SIZE=32
EPOCHS=1
LEARNING_RATE=2e-5
WEIGHT_DECAY=0.01
SEED=42

# HF model repo for the pretrained backbone + tokenizer.
MODEL_NAME=distilbert-base-uncased

# Output dir for checkpoints/artifacts outside MLflow (logs, tokenizer
# save dir, etc). MLflow still gets the model + metrics.
OUTPUT_DIR=training/runs
